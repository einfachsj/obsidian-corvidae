{
	"name": "corvidae",
	"version": "2.0.0",
	"description": "CORVIDAE Obsidian Plugin von ein.ink",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
